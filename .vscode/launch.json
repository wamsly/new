{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Backend (dev)",
      "request": "launch",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "runtimeExecutable": "pnpm",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "type": "node",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "NODE_ENV": "development",
        "DATABASE_URL": "postgresql://postgres:Admin321@localhost:5432/kuvote_db" // IMPORTANT: Replace with your actual PostgreSQL connection string
      }
      "preLaunchTask": "pnpm: build - backend"
    },
    {
      "name": "Launch Frontend (dev)",
      "request": "launch",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "runtimeExecutable": "pnpm",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "type": "node",
      "cwd": "${workspaceFolder}/frontend"
    }
  ]
}
